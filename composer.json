{
  "name": "blendbyte/coyote-cert",
"type": "library",
"license": "MIT",
  "require": {
    "php": "^8.3",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/log": "^3.0",
    "spatie/dns": "^2.7"
  },
  "require-dev": {
    "pestphp/pest": "^4.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.5"
  },
  "autoload": {
    "psr-4": {
      "CoyoteCert\\": "src"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test:coverage": "vendor/bin/pest --coverage",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=512M"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
